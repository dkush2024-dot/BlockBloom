# =============================================
# BlockBloom Backend — Environment Variables
# =============================================
# 1. Copy this file to .env:
#       Windows: copy .env.example .env
#       Mac/Linux: cp .env.example .env
#
# 2. Then run the setup script from the hardhat folder:
#       cd ../hardhat && npm run setup
#    This will automatically fill in DAO_FACTORY_ADDRESS and BLOOM_TOKEN_ADDRESS below.
#
# NEVER commit the .env file to version control.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
# Leave as-is for local dev — the backend uses an in-memory MongoDB automatically.
MONGODB_URI=mongodb://localhost:27017/blockbloom

# --- Blockchain (Local Hardhat Node) ---
# Leave as-is for local dev.
RPC_URL=http://127.0.0.1:8545

# --- Deployed contract addresses ---
# These are filled automatically when you run: cd ../hardhat && npm run setup
# Do NOT edit these manually.
DAO_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
BLOOM_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000

# --- AI (Gemini 1.5 Flash) ---
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# --- Redis (for AI memory & caching) ---
# Leave blank for local dev — the app uses a mock client if not set
REDIS_URL=
