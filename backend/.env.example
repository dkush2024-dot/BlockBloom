# =============================================
# BlockBloom Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/blockbloom

# --- Blockchain (Ethereum / Sepolia) ---
# Your Alchemy or Infura RPC URL
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Deployed contract addresses (update after deployment)
DAO_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
BLOOM_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
